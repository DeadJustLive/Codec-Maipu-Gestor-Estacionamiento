{
  "name": "Codec-Maipu",
  "version": "0.2.0",
  "language": "typescript",
  "strictMode": true,
  "stack": {
    "base": [
      "react",
      "typescript",
      "vite",
      "tailwind"
    ],
    "ui": "shadcn",
    "extensions": [
      "supabase",
      "@supabase/supabase-js",
      "@supabase/ssr"
    ],
    "domain": "parking"
  },
  "scopes": [
    "core",
    "parking",
    "incidents",
    "analytics"
  ],
  "platform": "pwa",
  "deploy": {
    "candidates": ["vercel", "google-cloud-run"],
    "decision": "pending"
  },
  "mcp": {
    "servers": {
      "OPL": "src/mcp-server.js"
    },
    "protocol": "json-rpc-2.0"
  }
}