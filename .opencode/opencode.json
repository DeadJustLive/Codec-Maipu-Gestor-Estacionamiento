{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "opl": {
      "type": "local",
      "command": [
        "openprompt-lang",
        "mcp"
      ],
      "enabled": true
    }
  },
  "agent": {
    "opl": {
      "description": "Agente OPL para anotaciones y validación con OpenPrompt Lang",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      }
    }
  },
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "default_agent": "opl",
  "instructions": [
    "AGENTS.md"
  ]
}